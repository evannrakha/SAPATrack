# ============================================================
# SAP Fleet & Quotation System — Environment Variables
# ============================================================
# 1. Salin file ini menjadi .env.local
# 2. Isi setiap variable dengan nilai dari Supabase dashboard
# 3. JANGAN commit .env.local ke Git
# ============================================================

# Dari Supabase: Settings → General → Project ID
# Format: https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here

# Buka .env.example, ganti komentar anon key menjadi:
# Format legacy: eyJhbGci... (dari tab Legacy di Supabase API Keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key-here